{
  "name": "opsh",
  "version": "0.1.5-alpha",
  "description": "A natural-language shell adapter for macOS and Linux.",
  "type": "module",
  "private": true,
  "bin": {
    "opsh": "./dist/bin/opsh.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:binary": "bun run build && node scripts/build-binary.mjs",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx src/bin/opsh.ts",
    "install:shell": "bash scripts/install.sh",
    "repl": "tsx src/bin/opsh.ts",
    "start": "node dist/bin/opsh.js",
    "uninstall:shell": "bash scripts/uninstall.sh"
  },
  "engines": {
    "node": ">=20.10"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "node-pty": "^1.1.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/prompts": "^2.4.9",
    "esbuild": "^0.25.9",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
